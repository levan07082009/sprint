generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  BUSINESS
  INDIVIDUAL
}

enum GigStatus {
  DRAFT
  ACTIVE
  PROGRESS
  COMPLETED
  CANCELLED
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model User {
  id                 String    @id @default(auto()) @map("_id") @db.ObjectId
  clerkId            String    @unique
  role               Role
  onboardingComplete Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  profile            Profile?
  gigs               Gig[]
  applications       Application[]
  sentMessages       Message[] @relation("SentMessages")
  reviewsGiven       Review[]  @relation("ReviewsGiven")
  reviewsReceived    Review[]  @relation("ReviewsReceived")
}

model Profile {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @unique @db.ObjectId
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName String
  avatarUrl   String?
  bio         String?
  trustScore  Int      @default(0)
  verified    Boolean  @default(false)
  hourlyRate  Float?
}

model Skill {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  name String
  type String // PHYSICAL, DIGITAL, TUTORING
  slug String @unique
}

model Gig {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  employerId     String    @db.ObjectId
  employer       User      @relation(fields: [employerId], references: [id])
  title          String
  description    String
  budget         Float
  currency       String    @default("USD")
  status         GigStatus @default(DRAFT)
  urgency        String    // STANDARD, ASAP
  requiredSkills String[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  applications   Application[]
  transactions   Transaction[]
  reviews        Review[]
}

model Application {
  id          String            @id @default(auto()) @map("_id") @db.ObjectId
  gigId       String            @db.ObjectId
  gig         Gig               @relation(fields: [gigId], references: [id])
  applicantId String            @db.ObjectId
  applicant   User              @relation(fields: [applicantId], references: [id])
  status      ApplicationStatus @default(PENDING)
  coverNote   String?
  proposedRate Float?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model Message {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  conversationId String   @db.ObjectId // Reference to a Conversation model or Gig
  senderId       String   @db.ObjectId
  sender         User     @relation("SentMessages", fields: [senderId], references: [id])
  content        String
  readAt         DateTime?
  createdAt      DateTime @default(now())
}

model Review {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  gigId      String   @db.ObjectId
  gig        Gig      @relation(fields: [gigId], references: [id])
  reviewerId String   @db.ObjectId
  reviewer   User     @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  revieweeId String   @db.ObjectId
  reviewee   User     @relation("ReviewsReceived", fields: [revieweeId], references: [id])
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
}

model Transaction {
  id                   String   @id @default(auto()) @map("_id") @db.ObjectId
  gigId                String   @db.ObjectId
  gig                  Gig      @relation(fields: [gigId], references: [id])
  stripePaymentIntentId String?
  amount               Float
  paymentMethod        String?  // e.g., "QR_CODE", "STRIPE", "CASH"
  qrCodeUrl            String?  // To store the URL or data for the generated QR code
  status               String   // ESCROW, RELEASED, REFUNDED, PENDING
  createdAt            DateTime @default(now())
}
